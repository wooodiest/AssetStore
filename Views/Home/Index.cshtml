@model HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
}

<div class="hero-section text-center">
    <h1>Asset Store</h1>
    <p class="lead col-lg-8 mx-auto">
        A digital asset marketplace for game creators - 3D models, textures, audio, and scripts.
        Browse, purchase, and download assets from independent creators.
    </p>
    <a class="btn btn-lg" asp-controller="Assets" asp-action="Index">Browse Catalog</a>
</div>

@if (Model.LatestAssets.Any())
{
    <h2 class="h4 mb-4 mt-4">Latest Assets</h2>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var asset in Model.LatestAssets)
        {
            <div class="col">
                <div class="card asset-card">
                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-secondary align-self-start mb-2">@asset.CategoryName</span>
                        <h5 class="card-title">@asset.Title</h5>
                        <div class="mt-auto d-flex justify-content-between align-items-center">
                            <strong class="asset-price">@asset.PriceDisplay</strong>
                            <a asp-controller="Assets" asp-action="Details" asp-route-id="@asset.Id"
                               class="btn btn-sm btn-primary">Details</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

