@model HomeIndexViewModel
@{
    ViewData["Title"] = "Strona główna";
}

<div class="text-center mb-5">
    <h1 class="display-4">Asset Store</h1>
    <p class="lead col-lg-8 mx-auto">
        Marketplace zasobów cyfrowych dla twórców gier — modele 3D, tekstury, audio i skrypty.
        Przeglądaj, kupuj i pobieraj assety od niezależnych twórców.
    </p>
    <a class="btn btn-primary btn-lg" asp-controller="Assets" asp-action="Index">Przeglądaj katalog</a>
</div>

@if (Model.LatestAssets.Any())
{
    <h2 class="h4 mb-3">Najnowsze assety</h2>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var asset in Model.LatestAssets)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-secondary align-self-start mb-2">@asset.CategoryName</span>
                        <h5 class="card-title">@asset.Title</h5>
                        <div class="mt-auto d-flex justify-content-between align-items-center">
                            <strong class="text-primary">@asset.PriceDisplay</strong>
                            <a asp-controller="Assets" asp-action="Details" asp-route-id="@asset.Id"
                               class="btn btn-sm btn-outline-primary">Szczegóły</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
