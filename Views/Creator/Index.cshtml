@model CreatorDashboardViewModel
@{
    ViewData["Title"] = "My Assets";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Creator Dashboard</h1>
    <a asp-controller="Assets" asp-action="Create" class="btn btn-primary">+ Add Asset</a>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h2 class="display-6">@Model.AssetCount</h2>
                <p class="text-muted mb-0">Published assets</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h2 class="display-6">@Model.TransactionCount</h2>
                <p class="text-muted mb-0">Downloads / purchases</p>
            </div>
        </div>
    </div>
</div>

@if (!Model.Assets.Any())
{
    <div class="alert alert-info">
        You don't have any assets yet.
        <a asp-controller="Assets" asp-action="Create">Add your first asset</a>.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Upload date</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var asset in Model.Assets)
                {
                    <tr>
                        <td>@asset.Title</td>
                        <td>@asset.CategoryName</td>
                        <td>@asset.PriceDisplay</td>
                        <td>@asset.UploadDate.ToString("yyyy-MM-dd")</td>
                        <td class="text-end">
                            <a asp-controller="Assets" asp-action="Details" asp-route-id="@asset.Id" class="btn btn-sm btn-outline-primary">Preview</a>
                            <a asp-controller="Assets" asp-action="Edit" asp-route-id="@asset.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

