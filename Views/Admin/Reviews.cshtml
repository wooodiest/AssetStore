@model AdminReviewListViewModel
@{
    ViewData["Title"] = "Review Moderation";
}

<h1>Review Moderation</h1>

@if (!Model.Reviews.Any())
{
    <div class="alert alert-info mt-4">No reviews to moderate.</div>
}
else
{
    <div class="table-responsive mt-4">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Asset</th>
                    <th>User</th>
                    <th>Rating</th>
                    <th>Comment</th>
                    <th>Date</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var review in Model.Reviews)
                {
                    <tr>
                        <td>
                            <a asp-controller="Assets" asp-action="Details" asp-route-id="@review.AssetId">@review.AssetTitle</a>
                        </td>
                        <td>@review.UserName</td>
                        <td>@review.Rating ★</td>
                        <td>@review.Comment</td>
                        <td>@review.PostedAt.ToString("yyyy-MM-dd")</td>
                        <td class="text-end">
                            <form asp-action="DeleteReview" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this review?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@review.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<p class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">← Admin dashboard</a>
</p>

