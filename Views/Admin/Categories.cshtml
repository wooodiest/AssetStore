@model CategoryListViewModel
@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Categories</h1>
    <a asp-action="CreateCategory" class="btn btn-primary">+ Add Category</a>
</div>

@if (!Model.Categories.Any())
{
    <div class="alert alert-info">No categories found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var category in Model.Categories)
                {
                    <tr>
                        <td>@category.Name</td>
                        <td>@category.Description</td>
                        <td class="text-end">
                            <a asp-action="EditCategory" asp-route-id="@category.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <form asp-action="DeleteCategory" asp-route-id="@category.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete category @category.Name?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<p class="mt-3">
        <a asp-action="Index" class="btn btn-outline-secondary">← Admin dashboard</a>

