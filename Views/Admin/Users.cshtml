@model AdminUserListViewModel
@{
    ViewData["Title"] = "Users";
}

<h1>Users</h1>
<p class="text-muted">Promote users to Creator role and block accounts.</p>

<div class="table-responsive mt-4">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Registration date</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr class="@(!user.IsActive ? "table-secondary" : "")">
                    <td>@user.Email</td>
                    <td>@user.Roles</td>
                    <td>
                        @if (user.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Blocked</span>
                        }
                    </td>
                    <td>@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td class="text-end">
                        @if (user.CanPromoteToCreator)
                        {
                            <form asp-action="PromoteToCreator" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-primary">Promote to Creator</button>
                            </form>
                        }
                        @if (user.IsActive)
                        {
                            <form asp-action="SetUserActive" method="post" class="d-inline"
                                  onsubmit="return confirm('Block user @user.Email?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.Id" />
                                <input type="hidden" name="isActive" value="false" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Block</button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="SetUserActive" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.Id" />
                                <input type="hidden" name="isActive" value="true" />
                                <button type="submit" class="btn btn-sm btn-outline-success">Unblock</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<p class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">← Admin dashboard</a>
</p>

