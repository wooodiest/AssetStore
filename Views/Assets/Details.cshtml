@model AssetDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="row">
    <div class="col-lg-8">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index">Katalog</a></li>
                <li class="breadcrumb-item active">@Model.Title</li>
            </ol>
        </nav>

        <h1>@Model.Title</h1>
        <p class="text-muted">
            <span class="badge bg-secondary">@Model.CategoryName</span>
            · @Model.CreatorName · @Model.UploadDate.ToString("yyyy-MM-dd")
        </p>

        <p class="lead">@Model.Description</p>

        <div class="d-flex align-items-center gap-3 mb-4">
            <h3 class="text-primary mb-0">@Model.PriceDisplay</h3>
            @if (Model.Reviews.Any())
            {
                <span class="text-warning">★ @Model.AverageRating.ToString("F1")</span>
                <span class="text-muted">(@Model.Reviews.Count recenzji)</span>
            }
        </div>

        <div class="d-flex flex-wrap gap-2 mb-4">
            @if (Model.ShowLoginPrompt)
            {
                <div class="alert alert-info w-100 mb-0">
                    <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@Context.Request.Path">Zaloguj się</a>,
                    aby kupić lub pobrać ten asset.
                </div>
            }
            else if (Model.CanPurchase)
            {
                <form asp-action="Purchase" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success">@Model.PurchaseButtonText</button>
                </form>
            }
            else if (Model.CanDownload)
            {
                <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-primary">Pobierz</a>
            }

            @if (Model.HasPurchased && !Model.IsOwner)
            {
                <a asp-controller="Transactions" asp-action="Index" class="btn btn-outline-secondary">Historia transakcji</a>
            }

            @if (Model.IsOwner || User.IsInRole(AppRoles.Administrator))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Edytuj</a>
            }
        </div>

        <h4>Recenzje</h4>

        @if (Model.CanReview)
        {
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title">Dodaj recenzję</h5>
                    <form asp-controller="Reviews" asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="AssetId" value="@Model.Id" />
                        <div class="mb-3">
                            <label for="rating" class="form-label">Ocena (1–5)</label>
                            <select class="form-select" id="rating" name="Rating" required>
                                <option value="5">5 — Doskonały</option>
                                <option value="4">4 — Bardzo dobry</option>
                                <option value="3">3 — Dobry</option>
                                <option value="2">2 — Słaby</option>
                                <option value="1">1 — Bardzo słaby</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="comment" class="form-label">Komentarz</label>
                            <textarea class="form-control" id="comment" name="Comment" rows="3" maxlength="2000" required
                                      placeholder="Opisz swoje wrażenia z tego asseta..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Opublikuj recenzję</button>
                    </form>
                </div>
            </div>
        }
        else if (Model.HasReviewed)
        {
            <p class="text-muted">Już dodałeś recenzję do tego asseta.</p>
        }

        @if (!Model.Reviews.Any())
        {
            <p class="text-muted">Brak recenzji.</p>
        }
        else
        {
            @foreach (var review in Model.Reviews)
            {
                <div class="card mb-2">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <strong>@review.UserName</strong>
                                <span class="text-warning ms-2">@string.Concat(Enumerable.Repeat("★", review.Rating))</span>
                            </div>
                            @if (User.IsInRole(AppRoles.Administrator))
                            {
                                <form asp-controller="Reviews" asp-action="Delete" method="post" class="d-inline"
                                      onsubmit="return confirm('Usunąć tę recenzję?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@review.Id" />
                                    <input type="hidden" name="assetId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Usuń</button>
                                </form>
                            }
                        </div>
                        <p class="mb-1 mt-2">@review.Comment</p>
                        <small class="text-muted">@review.PostedAt.ToString("yyyy-MM-dd")</small>
                    </div>
                </div>
            }
        }
    </div>
</div>
