@model TransactionHistoryViewModel
@{
    ViewData["Title"] = "Transaction History";
}

<h1>Transaction History</h1>
<p class="text-muted">List of assets you purchased or downloaded for free.</p>

@if (!Model.Items.Any())
{
    <div class="alert alert-info mt-4">
        You don't have any transactions yet.
        <a asp-controller="Assets" asp-action="Index">Browse the catalog</a>.
    </div>
}
else
{
    <div class="table-responsive mt-4">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Asset</th>
                    <th>Category</th>
                    <th>Amount</th>
                    <th>Date</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.AssetTitle</td>
                        <td>@item.CategoryName</td>
                        <td>@item.AmountDisplay</td>
                        <td>@item.PurchaseDate.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-end">
                            <a asp-controller="Assets" asp-action="Details" asp-route-id="@item.AssetId"
                               class="btn btn-sm btn-outline-primary">Details</a>
                            <a asp-controller="Assets" asp-action="Download" asp-route-id="@item.AssetId"
                               class="btn btn-sm btn-primary">Download</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

